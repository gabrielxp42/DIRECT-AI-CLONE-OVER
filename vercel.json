{
  "framework": "vite",
  "installCommand": "pnpm install --ignore-scripts=false",
  "buildCommand": "pnpm run build",
  "rewrites": [
    {
      "source": "/landing-page/(.*)",
      "destination": "/landing-page/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}